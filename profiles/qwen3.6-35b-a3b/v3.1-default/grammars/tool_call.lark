// profiles/qwen3.6-35b-a3b/v2/grammars/tool_call.lark
// Reactive XGrammar Lark grammar (D-11): vLLM applies this ONLY when
// @emmy/provider's callWithReactiveGrammar triggers a retry after the
// unconstrained first attempt failed to parse. Baseline (no-grammar) is
// the production path; this grammar is a correctness backstop per
// CLAUDE.md Pitfall #6.
//
// Shape: Qwen3.6 native OpenAI tool_calls envelope. The model emits
//   { "name": "<tool_name>", "arguments": { ... } }
// for each tool call. The grammar is deliberately over-accepting on the
// `arguments` object (any valid JSON); CONTEXT D-11 labels tightening
// per-tool as a Phase 5 move once SC-3 empirical data exists.
//
// Grammar covers all 8 native tools: read, write, edit, bash, grep, find,
// ls, web_fetch. MCP tools are not in the grammar (their shapes come from
// each MCP server at registration time; the reactive retry for MCP tool
// calls falls back to the unconstrained path with a diagnostic event).

start: tool_call

tool_call: "{" ws "\"name\"" ws ":" ws tool_name ws "," ws "\"arguments\"" ws ":" ws args_for_tool ws "}"

tool_name: "\"read\""
         | "\"write\""
         | "\"edit\""
         | "\"bash\""
         | "\"grep\""
         | "\"find\""
         | "\"ls\""
         | "\"web_fetch\""

// Any well-formed JSON object is accepted for arguments. D-11 backstop-not-shape-
// enforcer discipline: the parser in @emmy/tools validates per-tool shape against
// the JSON schemas in ../tool_schemas/; grammar only guarantees the envelope is
// parseable.
args_for_tool: object

object: "{" ws (kv (ws "," ws kv)*)? ws "}"
array: "[" ws (value (ws "," ws value)*)? ws "]"
kv: string ws ":" ws value
value: string | number | object | array | "true" | "false" | "null"

string: /"([^"\\]|\\["\\\/bfnrt]|\\u[0-9a-fA-F]{4})*"/
number: /-?(0|[1-9][0-9]*)(\.[0-9]+)?([eE][+-]?[0-9]+)?/
ws: /[ \t\n\r]*/
