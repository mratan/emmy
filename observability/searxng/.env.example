# observability/searxng/.env.example
#
# Plan 03.1-02 D-33 — SearxNG secret template.
#
# scripts/start_searxng.sh copies this to .env on first boot and fills the
# CHANGEME token with `openssl rand -hex 32`. The live .env is gitignored.
#
# ONE required field — SearxNG only needs a secret_key to sign browser cookies
# (which the emmy harness doesn't use; SearxNG's JSON API bypasses cookies).
# Still required by SearxNG's settings.yml validator.

SEARXNG_SECRET_KEY=CHANGEME
