# observability/langfuse/.env.example
#
# Template for observability/langfuse/.env (gitignored). scripts/start_observability.sh
# auto-generates `.env` on first boot by substituting every `CHANGEME` with a
# `openssl rand`-backed secret. DO NOT commit `.env` to git — it contains
# production-grade secrets (SALT, ENCRYPTION_KEY, CLICKHOUSE_PASSWORD, etc.).
#
# Workflow:
#   1. `bash scripts/start_observability.sh` — copies this file → .env and fills CHANGEME
#   2. Browser → http://localhost:3000 — create first user + project
#   3. Langfuse UI → Settings → API Keys → "Create new API keys"
#   4. Append the pk-lf-... / sk-lf-... values to `observability/langfuse/.env`
#      under LANGFUSE_PUBLIC_KEY / LANGFUSE_SECRET_KEY
#   5. Restart pi-emmy — boot banner now reads "OBSERVABILITY: ON — JSONL + Langfuse OTLP"

# Infrastructure secrets (start_observability.sh auto-fills via openssl rand)
NEXTAUTH_SECRET=CHANGEME-openssl-rand-base64-32
SALT=CHANGEME-openssl-rand-base64-16
ENCRYPTION_KEY=CHANGEME-openssl-rand-hex-32
CLICKHOUSE_PASSWORD=CHANGEME
REDIS_AUTH=CHANGEME
POSTGRES_PASSWORD=CHANGEME
MINIO_ROOT_PASSWORD=CHANGEME

# Langfuse S3 (minio) access keys — start_observability.sh auto-fills via openssl rand
LANGFUSE_S3_EVENT_UPLOAD_SECRET_ACCESS_KEY=CHANGEME
LANGFUSE_S3_MEDIA_UPLOAD_SECRET_ACCESS_KEY=CHANGEME
LANGFUSE_S3_BATCH_EXPORT_SECRET_ACCESS_KEY=CHANGEME

# Emmy-specific (MUST be filled manually after first Langfuse UI login)
#   pi-emmy reads these at boot; if unset and telemetry is enabled, pi-emmy prints
#   "Langfuse keys not set — running JSONL-only" and skips the OTLP exporter.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
