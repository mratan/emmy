# Emmy runtime artifacts — ignore contents by default, but allow specific
# phase-scoped evidence directories to be committed (Plan 02-08 verification
# contract). Gitignore rules cannot un-exclude a file whose parent directory
# is excluded, so we exclude individual file patterns rather than runs/ as a
# whole.
runs/**
!runs/.gitkeep
!runs/phase2-sc1/
!runs/phase2-sc1/**
!runs/phase2-sc2/
!runs/phase2-sc2/**
!runs/phase2-sc3/
!runs/phase2-sc3/**
!runs/phase2-sc3-capture/
!runs/phase2-sc3-capture/.gitkeep
!runs/phase2-sc4/
!runs/phase2-sc4/**
!runs/phase2-sc5/
!runs/phase2-sc5/**
!runs/phase4-kv/
!runs/phase4-kv/**
!runs/phase4-thermal/
!runs/phase4-thermal/**
!runs/phase4-sc1/
!runs/phase4-sc1/**
!runs/phase4-sc3/
!runs/phase4-sc3/**
!runs/phase4-sc4/
!runs/phase4-sc4/**
!runs/phase4-closeout/
!runs/phase4-closeout/**
!runs/phase4.1-qwen-kv/
!runs/phase4.1-qwen-kv/**
!runs/phase4.1-qwen-thermal/
!runs/phase4.1-qwen-thermal/**
!runs/phase4.1-gemma-kv/
!runs/phase4.1-gemma-kv/**
!runs/phase4.1-gemma-thermal/
!runs/phase4.1-gemma-thermal/**

# HF cache + models (never committed)
models/
hf-cache/

# Phase 3 SC-2 fixture — deterministic regenerable; hash is authoritative.
eval/phase3/fixtures/

