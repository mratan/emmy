# Python
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.venv/
.uv/
dist/
build/

# Editor / OS (MUST match emmy_serve.profile.hasher exclusion list — §4)
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo
*~
.*.swp

# Emmy runtime artifacts — ignore contents by default, but allow specific
# phase-scoped evidence directories to be committed (Plan 02-08 verification
# contract). Gitignore rules cannot un-exclude a file whose parent directory
# is excluded, so we exclude individual file patterns rather than runs/ as a
# whole.
runs/**
!runs/.gitkeep
!runs/phase2-sc1/
!runs/phase2-sc1/**
!runs/phase2-sc2/
!runs/phase2-sc2/**
!runs/phase2-sc3/
!runs/phase2-sc3/**
!runs/phase2-sc3-capture/
!runs/phase2-sc3-capture/.gitkeep
!runs/phase2-sc4/
!runs/phase2-sc4/**
!runs/phase2-sc5/
!runs/phase2-sc5/**
!runs/phase4-kv/
!runs/phase4-kv/**
!runs/phase4-thermal/
!runs/phase4-thermal/**
!runs/phase4-sc1/
!runs/phase4-sc1/**
!runs/phase4-sc3/
!runs/phase4-sc3/**
!runs/phase4-sc4/
!runs/phase4-sc4/**
!runs/phase4-closeout/
!runs/phase4-closeout/**
!runs/phase4.1-qwen-kv/
!runs/phase4.1-qwen-kv/**
!runs/phase4.1-qwen-thermal/
!runs/phase4.1-qwen-thermal/**
!runs/phase4.1-gemma-kv/
!runs/phase4.1-gemma-kv/**
!runs/phase4.1-gemma-thermal/
!runs/phase4.1-gemma-thermal/**

# HF cache + models (never committed)
models/
hf-cache/

# Phase 3 SC-2 fixture — deterministic regenerable; hash is authoritative.
eval/phase3/fixtures/

# Env
.env
.env.local
observability/langfuse/.env
observability/searxng/.env
observability/searxng/settings.yml

# Claude Code / agent local state — not part of the repo
.claude/

# Stray pi-emmy session transcripts dropped at repo root (real telemetry lives
# under ~/.emmy/telemetry/ via @emmy/telemetry, not at repo root).
/*.jsonl

# Stray top-level server logs (real serving evidence lives under runs/)
/server*.log

# Coding-session test artifacts — Emmy occasionally writes scratch projects at
# repo root during dogfooding sessions; ignore at top level so they don't
# accidentally land in PRs. Real source code lives under packages/, emmy_serve/,
# scripts/, etc.
/solar_system/

# Process-ID files from background helper scripts (download/pull pids) — runtime
# state, not evidence. The .log files from the same scripts ARE committed.
*.pid

# TS/Node
node_modules/
packages/*/dist/
.turbo/
