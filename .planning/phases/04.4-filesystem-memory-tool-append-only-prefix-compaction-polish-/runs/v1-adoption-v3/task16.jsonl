oject memory first. Notes there carry hard-won project knowledge — API quirks, co","profile":{"id":"qwen3.6-35b-a3b","version":"v3.1","hash":"sha256:4da61fd4eec31ba079204ce43119ff39ced0ae0f1989037cc2a68c5a89c272ba","path":"/data/projects/emmy/profiles/qwen3.6-35b-a3b/v3.1"}}
